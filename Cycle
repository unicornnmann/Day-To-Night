-- ============================================================
--  HOW LONG EACH PHASE LASTS
--  Proportional weights (they don't need to add to any number)
--  Tune these to make certain phases linger longer.
-- ============================================================

local PhaseWeights = {
    Dawn      = 1,   -- brief
    Morning   = 1.5,
    Midday    = 2,   -- longest bright window
    Afternoon = 1.5,
    Dusk      = 1,
    Evening   = 1,
    Night     = 2,   -- long night
    Midnight  = 1,
}

-- ============================================================
--  INTERNAL: compute phase durations from weights
-- ============================================================

local totalWeight = 0
for _, p in ipairs(Phases) do
    totalWeight = totalWeight + (PhaseWeights[p.name] or 1)
end

local phaseDurations = {}
for _, p in ipairs(Phases) do
    phaseDurations[p.name] = CYCLE_DURATION * ((PhaseWeights[p.name] or 1) / totalWeight)
end

-- ============================================================
--  APPLY LIGHTING (instant, used at script start)
-- ============================================================

local function applyLightingInstant(phase)
    Lighting.ClockTime      = phase.clockTime
    Lighting.Brightness     = phase.brightness
    Lighting.Ambient        = phase.ambient
    Lighting.OutdoorAmbient = phase.outdoorAmbient
    Lighting.FogColor       = phase.fogColor
    Lighting.FogEnd         = phase.fogEnd
    Lighting.ColorShift_Top = phase.colorShift_Top
    Lighting.ColorShift_Bottom = phase.colorShift_Bot
end

-- ============================================================
--  TWEEN LIGHTING (smooth transition)
-- ============================================================

local function tweenLighting(targetPhase)
    local tweenInfo = TweenInfo.new(
        TWEEN_TIME,
        Enum.EasingStyle.Linear,
        Enum.EasingDirection.InOut
    )

    -- ClockTime needs special handling: tween via a NumberValue proxy
    -- because Lighting.ClockTime is not a TweenService-compatible property directly
    -- We update it manually in a loop for smooth sky movement.

    local startClock = Lighting.ClockTime
    local endClock   = targetPhase.clockTime

    -- Handle midnight wrap (e.g. going from 21 → 0)
    local clockDelta = endClock - startClock
    if clockDelta > 12 then
        clockDelta = clockDelta - 24
    elseif clockDelta < -12 then
        clockDelta = clockDelta + 24
    end

    -- Tween all Color3 + number properties
    local lightingGoal = {
        Brightness          = targetPhase.brightness,
        Ambient             = targetPhase.ambient,
        OutdoorAmbient      = targetPhase.outdoorAmbient,
        FogColor            = targetPhase.fogColor,
        FogEnd              = targetPhase.fogEnd,
        ColorShift_Top      = targetPhase.colorShift_Top,
        ColorShift_Bottom   = targetPhase.colorShift_Bot,
    }

    local tween = TweenService:Create(Lighting, tweenInfo, lightingGoal)
    tween:Play()

    -- Manually lerp ClockTime over TWEEN_TIME seconds
    local elapsed = 0
    local connection
    connection = game:GetService("RunService").Heartbeat:Connect(function(dt)
        elapsed = elapsed + dt
        local alpha = math.clamp(elapsed / TWEEN_TIME, 0, 1)
        local newClock = startClock + clockDelta * alpha
        -- wrap around 24
        if newClock < 0 then newClock = newClock + 24 end
        if newClock >= 24 then newClock = newClock - 24 end
        Lighting.ClockTime = newClock
        if alpha >= 1 then
            connection:Disconnect()
        end
    end)

    return tween
end

-- ============================================================
--  MAIN CYCLE LOOP
-- ============================================================

-- Start at Dawn
local currentPhaseIndex = 1
applyLightingInstant(Phases[currentPhaseIndex])

print("[DayNightCycle] Started — Phase:", Phases[currentPhaseIndex].name)

while true do
    local phase = Phases[currentPhaseIndex]
    local duration = phaseDurations[phase.name]

    -- Wait through this phase (minus tween time so transition overlaps end)
    local waitTime = math.max(0, duration - TWEEN_TIME)
    task.wait(waitTime)

    -- Move to next phase
    currentPhaseIndex = (currentPhaseIndex % #Phases) + 1
    local nextPhase = Phases[currentPhaseIndex]

    print("[DayNightCycle] Transitioning to:", nextPhase.name)

    -- Start smooth transition
    local tween = tweenLighting(nextPhase)

    -- Wait for tween to finish before continuing
    tween.Completed:Wait()
end
