-- DayNightCycle (LocalScript)
-- Place inside: StarterPlayerScripts or StarterCharacterScripts
-- Cycles through: Dawn → Morning → Midday → Afternoon → Dusk → Evening → Night → Midnight
-- All client-side. Smoothly transitions lighting each phase.

local Lighting = game:GetService("Lighting")
local TweenService = game:GetService("TweenService")

-- ============================================================
--  CONFIGURATION
-- ============================================================

local CYCLE_DURATION  = 420   -- total seconds for one full day (7 min). Adjust freely.
local TWEEN_TIME      = 6     -- seconds to blend between phases (transition smoothness)

-- ============================================================
